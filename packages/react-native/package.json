{
  "name": "@scratcher/react-native",
  "version": "0.1.0",
  "description": "React Native bindings for scratcher core.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --dts --format esm,cjs",
    "dev": "tsup src/index.tsx --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73"
  },
  "dependencies": {
    "@scratcher/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "tsup": "^8.0.2",
    "typescript": "^5.8.2"
  }
}
