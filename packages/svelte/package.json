{
  "name": "@scratcher.js/svelte",
  "version": "1.0.0",
  "description": "A lightweight library for building expressive Scratch interactions.",
  "author": "kyechan99 <kyechan99@gmail.com>",
  "license": "MIT",
  "homepage": "https://kyechan99.github.io/scratcher.js",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "dev": "svelte-package -i src -o dist --watch",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "svelte-check --tsconfig ./tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "svelte": ">=5"
  },
  "dependencies": {
    "@scratcher.js/core": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.8.2"
  },
  "bugs": {
    "url": "https://github.com/kyechan99/scratcher.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyechan99/scratcher.js"
  },
  "keywords": [
    "scratch",
    "interaction",
    "scratcher",
    "scratch-card",
    "scratch-off"
  ]
}
