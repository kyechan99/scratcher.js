{
  "name": "@scratcher.js/vue",
  "version": "0.1.1",
  "description": "Cross-framework scratch interaction library for web and mobile.",
  "author": "kyechan99 <kyechan99@gmail.com>",
  "license": "MIT",
  "homepage": "https://kyechan99.github.io/scratcher.js",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "peerDependencies": {
    "vue": ">=3.4"
  },
  "dependencies": {
    "@scratcher.js/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.8.2",
    "vue": "^3.5.13"
  },
  "bugs": {
    "url": "https://github.com/kyechan99/scratcher.js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyechan99/scratcher.js"
  },
  "keywords": [
    "scratch",
    "interaction",
    "scratcher",
    "scratch-card",
    "scratch-off"
  ]
}
